<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc tsf-surgery-window-title}"
                      MinWidth="640"
                      MinHeight="400"
                      SetSize="760 520">
    <BoxContainer Orientation="Vertical" Margin="8 4">
        <Label Name="HintLabel"
               Text="{Loc tsf-surgery-window-hint}"
               StyleClasses="LabelSubText"
               Margin="0 0 0 6" />
        <PanelContainer StyleClasses="BackgroundPanel" Margin="0 0 0 4">
            <BoxContainer Name="LimbList"
                         Orientation="Vertical"
                         SeparationOverride="6"
                         Margin="4 4" />
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
